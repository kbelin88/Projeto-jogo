       if (dono === ladoRei) {
-        const { ordem, registro } = await decidirRei(estado, dono, cliente, opcoesPrompt);
+        const { ordem, registro } = opcoes.composto
+          ? await decidirReiComposto(estado, dono, cliente, opcoesPrompt, opcoes.composto)
